# PostgreSQL Database Connection URL (e.g. Neon.tech or Supabase Postgres)
# In production, use the direct or pooler connection URL.
DATABASE_URL="postgresql://username:password@hostname:port/database_name?sslmode=require"

# Google Cloud Console OAuth 2.0 Credentials
# Obtain these from APIs & Services > Credentials in Google Developer Console.
# Ensure that your Redirect URIs include:
# - http://localhost:3000/api/auth/callback/google  (for local development)
# - https://your-app-domain.vercel.app/api/auth/callback/google (for production)
GOOGLE_CLIENT_ID="your-google-client-id-here.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret-here"

# A secure random string used to sign JWT cookies.
# You can generate a 32-byte secret using: `openssl rand -base64 32`
JWT_SECRET="your-secure-jwt-secret-here"

# The whitelisted Google email address permitted to access the Admin Dashboard.
# Only this email will be allowed to log in as an administrator.
ADMIN_EMAIL="admin@example.com"
